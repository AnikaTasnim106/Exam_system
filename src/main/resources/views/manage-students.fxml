<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #1e1e2e;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.buet.edutrack.controllers.ManageStudentsController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #0f3460; -fx-padding: 20 30;">
            <Label style="-fx-font-size: 28px; -fx-text-fill: #f8ffbd; -fx-font-weight: bold;" text="Manage Students"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button onAction="#handleBack"
                    style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-padding: 10 25; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"
                    text="← Back"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="30" style="-fx-background-color: #1e1e2e;">
            <padding>
                <Insets bottom="40" left="50" right="50" top="40"/>
            </padding>

            <HBox spacing="20">
                <VBox alignment="CENTER" spacing="10"
                      style="-fx-background-color: linear-gradient(to bottom right, #667eea 0%, #764ba2 100%); -fx-background-radius: 15; -fx-padding: 25;"
                      HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 40px;" text="👥"/>
                    <Label fx:id="totalStudentsLabel"
                           style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;" text="0"/>
                    <Label style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 14px;" text="Total Students"/>
                </VBox>

                <VBox alignment="CENTER" spacing="10"
                      style="-fx-background-color: linear-gradient(to bottom right, #00C851 0%, #007E33 100%); -fx-background-radius: 15; -fx-padding: 25;"
                      HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 40px;" text="✓"/>
                    <Label fx:id="activeStudentsLabel"
                           style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;" text="0"/>
                    <Label style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 14px;" text="Active Students"/>
                </VBox>

                <VBox alignment="CENTER" spacing="10"
                      style="-fx-background-color: linear-gradient(to bottom right, #ffeaa7 0%, #fdcb6e 100%); -fx-background-radius: 15; -fx-padding: 25;"
                      HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 40px;" text="📈"/>
                    <Label fx:id="avgPerformanceLabel"
                           style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;" text="0%"/>
                    <Label style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 14px;" text="Avg Performance"/>
                </VBox>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="20"
                  style="-fx-background-color: #2b2b3c; -fx-background-radius: 15; -fx-padding: 20 30;">
                <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" text="Search:"/>
                <TextField fx:id="searchField" onKeyReleased="#handleSearch" promptText="Search by name or email..."
                           style="-fx-background-color: #363648; -fx-text-fill: white; -fx-prompt-text-fill: #888888; -fx-background-radius: 8; -fx-padding: 10; -fx-pref-width: 300;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="studentCountLabel"
                       style="-fx-text-fill: #6c63ff; -fx-font-size: 16px; -fx-font-weight: bold;" text="0 students"/>
            </HBox>

            <VBox spacing="15" style="-fx-background-color: #2b2b3c; -fx-background-radius: 15; -fx-padding: 30;">
                <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="👥 Student List"/>

                <TableView fx:id="studentsTable" prefHeight="400"
                           style="-fx-background-color: #363648; -fx-background-radius: 10; -fx-table-cell-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="usernameColumn" prefWidth="150" text="Username"
                                     style="-fx-text-fill: white;"/>
                        <TableColumn fx:id="emailColumn" prefWidth="220" text="Email"
                                     style="-fx-text-fill: white;"/>
                        <TableColumn fx:id="examsColumn" prefWidth="120" text="Exams Taken"
                                     style="-fx-text-fill: white;"/>
                        <TableColumn fx:id="avgScoreColumn" prefWidth="120" text="Avg Score"
                                     style="-fx-text-fill: white;"/>
                        <TableColumn fx:id="bestGradeColumn" prefWidth="100" text="Best Grade"
                                     style="-fx-text-fill: white;"/>
                        <TableColumn fx:id="lastActiveColumn" prefWidth="150" text="Last Active"
                                     style="-fx-text-fill: white;"/>
                        <TableColumn fx:id="actionsColumn" prefWidth="120" text="Actions"
                                     style="-fx-text-fill: white;"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
            <VBox fx:id="emptyStateBox" alignment="CENTER" managed="false" spacing="15"
                  style="-fx-background-color: #2b2b3c; -fx-background-radius: 15; -fx-padding: 60;" visible="false">
                <Label style="-fx-font-size: 60px;" text="👥"/>
                <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"
                       text="No Students Found"/>
                <Label style="-fx-text-fill: #b0b0b0; -fx-font-size: 14px;"
                       text="Students will appear here once they sign up"/>
            </VBox>

        </VBox>
    </center>

</BorderPane>