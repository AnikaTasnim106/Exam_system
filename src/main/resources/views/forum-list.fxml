<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.edutrack.controllers.ForumListController">

   <!-- Top Bar -->
   <HBox prefHeight="80.0" style="-fx-background-color: #2b2b3c;" VBox.vgrow="NEVER">
      <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
      <Label style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" text="Forum" />
      <Region HBox.hgrow="ALWAYS" />
      <Button fx:id="newPostButton" mnemonicParsing="false" onAction="#handleNewPost" style="-fx-background-color: #6c63ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-border-color: #6c63ff; -fx-border-width: 1; -fx-border-radius: 8;" text="+ New Post" />
      <Region prefWidth="10" />
      <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #2d1b69; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #6c63ff; -fx-border-width: 1; -fx-border-radius: 8; -fx-padding: 10 20;" text="← Back" />
   </HBox>

   <!-- Filter Bar -->
   <HBox fillHeight="false" prefHeight="50.0" spacing="15.0" style="-fx-background-color: #2b2b3c; -fx-border-color: #363648; -fx-border-width: 1 0 0 0;">
      <padding><Insets bottom="10.0" left="20.0" right="20.0" top="10.0" /></padding>
      <ComboBox fx:id="subjectFilterCombo" onAction="#handleFilter" prefHeight="30.0" prefWidth="180.0" />
      <Label fx:id="postCountLabel" style="-fx-text-fill: #b0b0b0; -fx-font-size: 13px;" text="Showing 0 posts" />
   </HBox>

   <!-- Posts List -->
   <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #1e1e2e;" VBox.vgrow="ALWAYS">
      <content>
         <VBox fx:id="postsContainer" spacing="15.0" style="-fx-background-color: #1e1e2e;">
            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
         </VBox>
      </content>
   </ScrollPane>

</VBox>