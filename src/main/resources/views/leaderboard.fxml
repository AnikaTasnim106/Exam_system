<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="1200.0" style="-fx-background-color: #1e1e2e;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.edutrack.controllers.LeaderboardController">
   <children>
      <HBox prefHeight="80.0" prefWidth="1200.0" style="-fx-background-color: #2b2b3c;">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <Label fx:id="titleLabel" prefWidth="900.0" style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;" text="🏆 Leaderboard" />
            <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #6c63ff; -fx-text-fill: white; -fx-background-radius: 8;" text="← Back" />
         </children>
      </HBox>
      <HBox prefHeight="50.0" prefWidth="1200.0" spacing="15.0" style="-fx-background-color: #2b2b3c; -fx-border-color: #363648; -fx-border-width: 1 0 0 0;">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label style="-fx-text-fill: #b0b0b0; -fx-font-size: 14px;" text="Filter by Subject:" />
            <ComboBox fx:id="subjectFilterCombo" onAction="#handleFilter" prefHeight="30.0" prefWidth="180.0" />
         </children>
      </HBox>
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #1e1e2e;" VBox.vgrow="ALWAYS">
         <content>
            <VBox fx:id="leaderboardContainer" spacing="10.0" style="-fx-background-color: #1e1e2e;">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</VBox>
